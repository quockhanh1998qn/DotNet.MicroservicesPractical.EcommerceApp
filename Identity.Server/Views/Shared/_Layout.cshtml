<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - Tedu Identity</title>
	<style>
		* { box-sizing: border-box; }
		body { font-family: 'Segoe UI', Roboto, sans-serif; background: linear-gradient(135deg, #4f46e5, #7c3aed); margin: 0; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
		.card { background: #fff; border-radius: 12px; box-shadow: 0 20px 60px rgba(0,0,0,.25); padding: 2.5rem; width: 100%; max-width: 420px; }
		h1 { margin: 0 0 1.5rem; color: #1f2937; font-size: 1.5rem; }
		.brand { font-size: .85rem; color: #6b7280; letter-spacing: .1em; text-transform: uppercase; margin-bottom: .5rem; }
		label { display: block; font-size: .85rem; color: #374151; margin: .75rem 0 .25rem; font-weight: 600; }
		input[type=email], input[type=password], input[type=text] { width: 100%; padding: .65rem .75rem; border: 1px solid #d1d5db; border-radius: 6px; font-size: 1rem; }
		input:focus { outline: 2px solid #6366f1; border-color: transparent; }
		.checkbox { display: flex; align-items: center; gap: .5rem; margin: 1rem 0; font-size: .9rem; color: #4b5563; }
		button { width: 100%; background: #4f46e5; color: #fff; border: 0; padding: .75rem; border-radius: 6px; font-size: 1rem; font-weight: 600; cursor: pointer; margin-top: 1rem; }
		button:hover { background: #4338ca; }
		.errors { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; border-radius: 6px; padding: .65rem .75rem; margin-bottom: 1rem; font-size: .9rem; }
		.hint { background: #f3f4f6; color: #4b5563; border-radius: 6px; padding: .75rem; margin-top: 1.25rem; font-size: .8rem; }
		.hint code { background: #e5e7eb; padding: 1px 4px; border-radius: 3px; }
	</style>
</head>
<body>
	<div class="card">
		<div class="brand">Tedu Microservices</div>
		@RenderBody()
	</div>
</body>
</html>

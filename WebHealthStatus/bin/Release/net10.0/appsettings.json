{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "HealthChecksUI": {
    "HealthChecks": [
      { "Name": "Product.API",   "Uri": "http://localhost:5102/health" },
      { "Name": "Customer.API",  "Uri": "http://localhost:5103/health" },
      { "Name": "Basket.API",    "Uri": "http://localhost:5004/health" },
      { "Name": "Ordering.API",  "Uri": "http://localhost:5005/health" },
      { "Name": "Inventory.API", "Uri": "http://localhost:5006/health" },
      { "Name": "HangFire.API",  "Uri": "http://localhost:5007/health" }
    ],
    "Webhooks": [],
    "EvaluationTimeInSeconds": 30,
    "MinimumSecondsBetweenFailureNotifications": 60
  }
}
